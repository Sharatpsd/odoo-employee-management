<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- Designation List View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_designation_list" model="ir.ui.view">
        <field name="name">employee.management.designation.list</field>
        <field name="model">employee.management.designation</field>

        <field name="arch" type="xml">
            <list string="Designations">
                <field name="name"/>
                <field name="department_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- ========================================================= -->
    <!-- Designation Form View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_designation_form" model="ir.ui.view">
        <field name="name">employee.management.designation.form</field>
        <field name="model">employee.management.designation</field>

        <field name="arch" type="xml">
            <form string="Designation">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_employees"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-users">
                            <field name="employee_count" widget="statinfo" string="Employees"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Designation Name"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="active"/>
                        </group>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ========================================================= -->
    <!-- Designation Search View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_designation_search" model="ir.ui.view">
        <field name="name">employee.management.designation.search</field>
        <field name="model">employee.management.designation</field>

        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="department_id"/>

                <filter
                    name="active"
                    string="Active"
                    domain="[('active', '=', True)]"/>

                <filter
                    name="inactive"
                    string="Inactive"
                    domain="[('active', '=', False)]"/>

            </search>
        </field>
    </record>

    <!-- ========================================================= -->
    <!-- Designation Action -->
    <!-- ========================================================= -->

    <record id="action_employee_management_designation" model="ir.actions.act_window">
        <field name="name">Designations</field>
        <field name="res_model">employee.management.designation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_employee_management_designation_search"/>
    </record>

</odoo>