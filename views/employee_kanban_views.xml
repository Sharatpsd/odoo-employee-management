<?xml version="1.0" encoding="utf-8"?>
<odoo>

<!-- ========================================================= -->
<!-- Employee Kanban View -->
<!-- ========================================================= -->

<record id="view_employee_management_employee_kanban" model="ir.ui.view">
    <field name="name">employee.management.employee.kanban</field>
    <field name="model">employee.management.employee</field>

    <field name="arch" type="xml">
        <kanban class="o_kanban_mobile o_employee_kanban" default_group_by="department_id">

            <templates>
                <t t-name="card">
                    <div t-attf-class="oe_kanban_global_click d-flex p-3 gap-3 align-items-start border-start border-4 rounded-2 shadow-sm
                        {{ status == 'draft' ? 'border-warning' :
                           status == 'confirmed' ? 'border-primary' :
                           status == 'active' ? 'border-success' :
                           status == 'leave' ? 'border-info' :
                           status == 'resigned' ? 'border-danger' : 'border-secondary' }}">

                        <!-- Avatar -->
                        <div class="o_kanban_image flex-shrink-0">
                            <field name="image_1920"
                                   widget="image"
                                   class="oe_avatar rounded-circle border"
                                   options="{'size': [56, 56]}"/>
                        </div>

                        <!-- Main details -->
                        <div class="oe_kanban_details d-flex flex-column flex-grow-1 overflow-hidden">

                            <div class="d-flex justify-content-between align-items-start">
                                <div class="fw-bold fs-6 text-truncate">
                                    <field name="name"/>
                                </div>

                                <!-- Card action menu -->
                                <div class="dropdown flex-shrink-0" role="button">
                                    <a class="dropdown-toggle o_kanban_manage_toggle_button text-muted"
                                       data-bs-toggle="dropdown" href="#" role="button" aria-label="More" title="More">
                                        <i class="fa fa-ellipsis-v"/>
                                    </a>
                                    <div class="dropdown-menu dropdown-menu-end" role="menu">
                                        <a role="menuitem" type="open" class="dropdown-item">
                                            <i class="fa fa-pencil me-2"/>Edit
                                        </a>
                                        <a role="menuitem" type="object" name="toggle_active" class="dropdown-item">
                                            <i class="fa fa-archive me-2"/>Archive / Unarchive
                                        </a>
                                        <a role="menuitem" type="delete" class="dropdown-item text-danger">
                                            <i class="fa fa-trash me-2"/>Delete
                                        </a>
                                    </div>
                                </div>
                            </div>

                            <span class="badge text-bg-light border text-muted fw-normal mb-1" style="width: fit-content;">
                                <i class="fa fa-hashtag me-1 small"/>
                                <field name="employee_code"/>
                            </span>

                            <div class="text-muted small text-truncate">
                                <i class="fa fa-building me-1"/>
                                <field name="department_id"/>
                            </div>

                            <div class="text-muted small text-truncate mb-2">
                                <i class="fa fa-briefcase me-1"/>
                                <field name="designation_id"/>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <field name="status"
                                       widget="badge"
                                       decoration-warning="status == 'draft'"
                                       decoration-primary="status == 'confirmed'"
                                       decoration-success="status == 'active'"
                                       decoration-info="status == 'leave'"
                                       decoration-danger="status == 'resigned'"/>
                            </div>
                        </div>

                    </div>
                </t>
            </templates>
        </kanban>
    </field>
</record>

</odoo>