<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- Employee Kanban View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_employee_kanban" model="ir.ui.view">
        <field name="name">employee.management.employee.kanban</field>
        <field name="model">employee.management.employee</field>

        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="department_id">

                <field name="id"/>
                <field name="image_1920"/>
                <field name="name"/>
                <field name="employee_code"/>
                <field name="department_id"/>
                <field name="designation_id"/>
                <field name="status"/>

                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click d-flex flex-row p-2 gap-3 align-items-center">

                            <div class="o_kanban_image">
                                <field name="image_1920" widget="image" class="oe_avatar rounded-circle"/>
                            </div>

                            <div class="oe_kanban_details d-flex flex-column flex-grow-1">
                                <div class="fw-bold fs-5 text-truncate">
                                    <field name="name"/>
                                </div>

                                <div class="text-muted small">
                                    <field name="employee_code"/>
                                </div>

                                <div class="text-muted small mt-1">
                                    <i class="fa fa-building me-1"/>
                                    <field name="department_id"/>
                                </div>

                                <div class="text-muted small">
                                    <i class="fa fa-briefcase me-1"/>
                                    <field name="designation_id"/>
                                </div>

                                <div class="mt-2">
                                    <field name="status"
                                           widget="badge"
                                           decoration-warning="status == 'draft'"
                                           decoration-primary="status == 'confirmed'"
                                           decoration-success="status == 'active'"
                                           decoration-info="status == 'leave'"
                                           decoration-danger="status == 'resigned'"/>
                                </div>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

</odoo>
