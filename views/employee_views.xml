<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- Employee List View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_employee_list" model="ir.ui.view">
        <field name="name">employee.management.employee.list</field>
        <field name="model">employee.management.employee</field>
        <field name="arch" type="xml">
            <list string="Employees">

                <field name="image_1920" widget="image"/>
                <field name="employee_code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="designation_id"/>
                <field name="status"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="joining_date"/>
                <field name="active"/>

            </list>
        </field>
    </record>


    <!-- ========================================================= -->
    <!-- Employee Form View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_employee_form" model="ir.ui.view">
        <field name="name">employee.management.employee.form</field>
        <field name="model">employee.management.employee</field>
        <field name="arch" type="xml">

            <form string="Employee">

                <header>

                    <button
                        name="action_confirm"
                        type="object"
                        string="Confirm"
                        class="btn-primary"
                        invisible="status != 'draft'"/>

                    <button
                        name="action_activate"
                        type="object"
                        string="Activate"
                        class="btn-success"
                        invisible="status != 'confirmed'"/>

                    <button
                        name="action_leave"
                        type="object"
                        string="Leave"
                        invisible="status != 'active'"/>

                    <button
                        name="action_resign"
                        type="object"
                        string="Resign"
                        class="btn-danger"
                        invisible="status == 'resigned'"/>

                    <button
                        name="action_reset_draft"
                        type="object"
                        string="Reset"
                        invisible="status == 'draft'"/>

                    <field
                        name="status"
                        widget="statusbar"
                        statusbar_visible="draft,confirmed,active,leave,resigned"/>

                </header>

                <sheet>

                    <field
                        name="image_1920"
                        widget="image"
                        class="oe_avatar"
                        options="{'preview_image': 'image_1920'}"/>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field
                                name="name"
                                placeholder="Employee Name"/>
                        </h1>
                    </div>

                    <group>

                        <group string="Employee Information">

                            <field
                                name="employee_code"
                                readonly="1"/>

                            <field name="department_id"/>

                            <field name="designation_id"/>

                            <field name="joining_date"/>

                        </group>

                        <group string="Personal Information">

                            <field name="date_of_birth"/>

                            <field
                                name="age"
                                readonly="1"/>

                            <field
                                name="email"
                                widget="email"/>

                            <field
                                name="phone"
                                widget="phone"/>

                            <field name="active"/>

                        </group>

                    </group>

                    <notebook>

                        <page string="Notes">

                            <field
                                name="notes"
                                placeholder="Internal Notes..."/>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>


    <!-- ========================================================= -->
    <!-- Employee Search View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_employee_search"
            model="ir.ui.view">

        <field name="name">
            employee.management.employee.search
        </field>

        <field name="model">
            employee.management.employee
        </field>

        <field name="arch" type="xml">

            <search>

                <field name="employee_code"/>
                <field name="name"/>
                <field name="department_id"/>
                <field name="designation_id"/>
                <field name="email"/>
                <field name="status"/>

                <separator/>

                <filter
                    name="active"
                    string="Active"
                    domain="[('active','=',True)]"/>

                <filter
                    name="inactive"
                    string="Inactive"
                    domain="[('active','=',False)]"/>

                <group
                    expand="0"
                    string="Group By">

                    <filter
                        string="Department"
                        context="{'group_by':'department_id'}"/>

                    <filter
                        string="Designation"
                        context="{'group_by':'designation_id'}"/>

                    <filter
                        string="Status"
                        context="{'group_by':'status'}"/>

                </group>

            </search>

        </field>

    </record>


    <!-- ========================================================= -->
    <!-- Action -->
    <!-- ========================================================= -->

    <record
        id="action_employee_management_employee"
        model="ir.actions.act_window">

        <field name="name">
            Employees
        </field>

      <field name="res_model">employee.management.employee</field>
        <field name="view_mode">
            kanban,list,form
        </field>

        <field
            name="search_view_id"
            ref="view_employee_management_employee_search"/>

    </record>


    <!-- ========================================================= -->
    <!-- Menu -->
    <!-- ========================================================= -->

    <menuitem
        id="menu_employee_management_root"
        name="Employee Management"
        sequence="10"/>

    <menuitem
        id="menu_employee_management_employee"
        name="Employees"
        parent="menu_employee_management_root"
        action="action_employee_management_employee"
        sequence="10"/>

</odoo>