<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ========================================================= -->
    <!-- Asset List View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_asset_list" model="ir.ui.view">
        <field name="name">employee.management.asset.list</field>
        <field name="model">employee.management.asset</field>

        <field name="arch" type="xml">
            <list string="Employee Assets"
                  decoration-success="status == 'assigned'"
                  decoration-info="status == 'available'"
                  decoration-muted="status == 'returned'"
                  decoration-danger="status == 'damaged'"
                  decoration-warning="status == 'disposed'">

                <field name="asset_code"/>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="category"/>
                <field name="serial_number" optional="show"/>
                <field name="assigned_date"/>
                <field name="return_date" optional="show"/>
                <field name="status"
                       widget="badge"
                       decoration-success="status == 'assigned'"
                       decoration-info="status == 'available'"
                       decoration-muted="status == 'returned'"
                       decoration-danger="status == 'damaged'"
                       decoration-warning="status == 'disposed'"/>
                <field name="active" optional="hide"/>

            </list>
        </field>
    </record>

    <!-- ========================================================= -->
    <!-- Asset Form View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_asset_form" model="ir.ui.view">
        <field name="name">employee.management.asset.form</field>
        <field name="model">employee.management.asset</field>

        <field name="arch" type="xml">
            <form string="Employee Asset">

                <sheet>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Asset Name"/>
                        </h1>
                    </div>

                    <group>

                        <group string="Asset Information">
                            <field name="asset_code"/>
                            <field name="category"/>
                            <field name="serial_number"/>
                            <field name="purchase_date"/>
                            <field name="status"/>
                            <field name="active"/>
                        </group>

                        <group string="Assignment">
                            <field name="employee_id"/>
                            <field name="assigned_date"/>
                            <field name="return_date"/>
                        </group>

                    </group>

                    <notebook>
                        <page string="Notes">
                            <field name="notes"
                                   placeholder="Additional notes about this asset..."/>
                        </page>
                    </notebook>

                </sheet>

            </form>
        </field>
    </record>

    <!-- ========================================================= -->
    <!-- Asset Search View -->
    <!-- ========================================================= -->

    <record id="view_employee_management_asset_search" model="ir.ui.view">
        <field name="name">employee.management.asset.search</field>
        <field name="model">employee.management.asset</field>

        <field name="arch" type="xml">
            <search>

                <field name="name"/>
                <field name="asset_code"/>
                <field name="employee_id"/>
                <field name="serial_number"/>

                <!-- Status Filters -->
                <filter name="filter_assigned"
                        string="Assigned"
                        domain="[('status', '=', 'assigned')]"/>
                <filter name="filter_available"
                        string="Available"
                        domain="[('status', '=', 'available')]"/>
                <filter name="filter_returned"
                        string="Returned"
                        domain="[('status', '=', 'returned')]"/>
                <filter name="filter_damaged"
                        string="Damaged"
                        domain="[('status', '=', 'damaged')]"/>

                <separator/>

                <!-- Category Filters -->
                <filter name="filter_laptop"
                        string="Laptops"
                        domain="[('category', '=', 'laptop')]"/>
                <filter name="filter_phone"
                        string="Phones"
                        domain="[('category', '=', 'phone')]"/>
                <filter name="filter_vehicle"
                        string="Vehicles"
                        domain="[('category', '=', 'vehicle')]"/>

                <separator/>

                <!-- Group By -->
                <filter name="group_employee"
                        string="Employee"
                        context="{'group_by': 'employee_id'}"/>
                <filter name="group_category"
                        string="Category"
                        context="{'group_by': 'category'}"/>
                <filter name="group_status"
                        string="Status"
                        context="{'group_by': 'status'}"/>

            </search>
        </field>
    </record>

    <!-- ========================================================= -->
    <!-- Asset Action -->
    <!-- ========================================================= -->

    <record id="action_employee_management_asset" model="ir.actions.act_window">
        <field name="name">Employee Assets</field>
        <field name="res_model">employee.management.asset</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_employee_management_asset_search"/>
    </record>

</odoo>
